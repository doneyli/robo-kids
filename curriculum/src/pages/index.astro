---
import Base from '../layouts/Base.astro';
---
<Base title="Home" description="12-Week Family Robotics Curriculum for ages 4–8 using Reachy Mini">
  <!-- Hero -->
  <div class="bg-gradient-to-br from-gray-900 to-gray-700 text-white py-20 px-6 text-center">
    <div class="text-6xl mb-4">🤖</div>
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">12-Week Family Robotics Curriculum</h1>
    <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8">
      Two parallel tracks for learning robotics with Reachy Mini — designed for 1–2 hours per week.
      Works with or without physical hardware (simulator-first!).
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/little-explorers" class="bg-explorer-500 hover:bg-explorer-600 text-white font-bold px-8 py-4 rounded-2xl text-lg transition-colors">
        🌟 Little Explorers <span class="text-sm font-normal opacity-80">(Age 4)</span>
      </a>
      <a href="/young-builders" class="bg-builder-500 hover:bg-builder-600 text-white font-bold px-8 py-4 rounded-2xl text-lg transition-colors">
        🔧 Young Builders <span class="text-sm font-normal opacity-80">(Age 8)</span>
      </a>
    </div>
  </div>

  <!-- Tracks overview -->
  <div class="max-w-5xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-8">
    <!-- Little Explorers -->
    <div class="rounded-2xl border-2 border-explorer-200 bg-explorer-50 p-6">
      <div class="text-4xl mb-3">🌟</div>
      <h2 class="text-2xl font-extrabold text-explorer-700 mb-2">Little Explorers</h2>
      <p class="text-gray-600 mb-4">Age 4 · 30-min sessions · Play-based learning</p>
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-yellow-400 flex items-center justify-center text-xs font-bold text-white">1–3</span>
          <span class="text-sm font-medium">Unplugged Activities</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-orange-400 flex items-center justify-center text-xs font-bold text-white">4–6</span>
          <span class="text-sm font-medium">Meet Reachy Mini</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-pink-400 flex items-center justify-center text-xs font-bold text-white">7–9</span>
          <span class="text-sm font-medium">Creative Play</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-red-400 flex items-center justify-center text-xs font-bold text-white">10–12</span>
          <span class="text-sm font-medium">Mini Projects</span>
        </div>
      </div>
      <a href="/little-explorers" class="mt-5 inline-block bg-explorer-500 text-white font-bold px-5 py-2 rounded-xl hover:bg-explorer-600 transition-colors">
        View Track →
      </a>
    </div>

    <!-- Young Builders -->
    <div class="rounded-2xl border-2 border-builder-200 bg-builder-50 p-6">
      <div class="text-4xl mb-3">🔧</div>
      <h2 class="text-2xl font-extrabold text-builder-700 mb-2">Young Builders</h2>
      <p class="text-gray-600 mb-4">Age 8 · 60-min sessions · Structured learning</p>
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-cyan-400 flex items-center justify-center text-xs font-bold text-white">1–3</span>
          <span class="text-sm font-medium">Computational Thinking</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-blue-400 flex items-center justify-center text-xs font-bold text-white">4–6</span>
          <span class="text-sm font-medium">Reachy Basics</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-violet-400 flex items-center justify-center text-xs font-bold text-white">7–9</span>
          <span class="text-sm font-medium">AI Projects</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-indigo-500 flex items-center justify-center text-xs font-bold text-white">10–12</span>
          <span class="text-sm font-medium">Capstone</span>
        </div>
      </div>
      <a href="/young-builders" class="mt-5 inline-block bg-builder-500 text-white font-bold px-5 py-2 rounded-xl hover:bg-builder-600 transition-colors">
        View Track →
      </a>
    </div>
  </div>

  <!-- How it works -->
  <div class="bg-white border-t border-gray-200 py-12 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-extrabold mb-8">Every lesson includes</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-left">
        {[
          ['🎯', 'Learning Objective'],
          ['🛠️', 'Materials List'],
          ['📋', 'Step-by-Step Instructions'],
          ['💬', 'Reflection Questions'],
          ['👪', 'Parent Tips'],
          ['💻', 'Code Snippets'],
        ].map(([icon, label]) => (
          <div class="flex items-center gap-3 bg-gray-50 rounded-xl p-3">
            <span class="text-2xl">{icon}</span>
            <span class="font-semibold text-sm text-gray-700">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</Base>
